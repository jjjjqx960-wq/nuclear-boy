<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application>
        <!-- 调试诊断入口：adb shell am broadcast -a com.nuclearboy.app.RUN_DIAGNOSTICS
             仅 debug 构建注册；接收器代码内部也有 BuildConfig.DEBUG 双重校验 -->
        <receiver
            android:name="com.nuclearboy.app.diagnostics.DiagnosticsReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.nuclearboy.app.RUN_DIAGNOSTICS" />
            </intent-filter>
        </receiver>

        <!-- 调试配置入口：通过 ADB 写入第三方模型并选中。
             仅 debug 构建注册；接收器内部禁止输出明文 Key。 -->
        <receiver
            android:name="com.nuclearboy.app.diagnostics.DebugModelConfigReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.nuclearboy.app.DEBUG_SAVE_CUSTOM_MODEL" />
            </intent-filter>
        </receiver>

        <!-- 调试配置入口：通过 ADB 写入远程电脑桥接配置。
             仅 debug 构建注册；接收器内部禁止输出明文 token。 -->
        <receiver
            android:name="com.nuclearboy.app.diagnostics.DebugPcBridgeConfigReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.nuclearboy.app.DEBUG_SAVE_PC_BRIDGE" />
            </intent-filter>
        </receiver>

        <!-- 调试会话入口：写入固定测试对话，便于真机验证聊天 UI 状态。
             仅 debug 构建注册；接收器内部再次校验 BuildConfig.DEBUG。 -->
        <receiver
            android:name="com.nuclearboy.app.diagnostics.DebugConversationSeedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.nuclearboy.app.DEBUG_SEED_CONVERSATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
