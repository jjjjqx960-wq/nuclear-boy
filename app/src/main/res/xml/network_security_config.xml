<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Official endpoints stay HTTPS-only. -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.deepseek.com</domain>
        <domain includeSubdomains="true">platform.deepseek.com</domain>
        <domain includeSubdomains="true">cdn.deepseek.com</domain>
    </domain-config>
    <!-- User-configured OpenAI-compatible gateways may be private HTTP services. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
